# Registry UI server
SERVER_ADDR=:8080
# HTTPS/TLS is managed from the Settings page in the UI: toggle it on, upload a
# certificate + private key (PEM, paste or file), then restart the service.
# The cert/key are stored under CERT_DIR (see below). No env switch needed.


# Lightweight Harbor-like auth. When AUTH_MODE=basic, the Web UI and /api
# require a DB-managed user (the default admin/change-me is seeded on
# first startup — change it immediately).
AUTH_MODE=basic
# V2_AUTH_MODE=ui: /v2 requires a UI user and forwards the request's
# own Authorization header upstream (or falls back to REGISTRY_USERNAME/PASSWORD).
# V2_AUTH_MODE=registry: /v2 uses configured registry credentials upstream, leaving registry auth semantics unchanged.
V2_AUTH_MODE=ui

# Backing Docker Registry. Single registry only; UI has no registry management.
REGISTRY_URL=http://registry:5000
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
REGISTRY_BEARER_TOKEN=
REGISTRY_TLS_SKIP_VERIFY=false

# UI/backend delete guard. Registry itself must also enable delete.
ENABLE_DELETE=true

# SSRF guard for webhooks. When false (default), webhook target URLs that
# resolve to loopback / link-local / private addresses are rejected. Set to
# true only if you intentionally call internal endpoints from webhooks.
ALLOW_WEBHOOK_PRIVATE_IP=false

# One persistent root. Mount/copy this whole directory for backup and migration.
# Subdirs: db/ SQLite, certs/ TLS certs, uploads/ uploaded logos/assets, registry/ embedded or compose registry storage.
DATA_DIR=./data
SQLITE_PATH=./data/db/registry-ui.db
UPLOAD_DIR=./data/uploads
CERT_DIR=./data/certs
REGISTRY_DATA_DIR=./data/registry
